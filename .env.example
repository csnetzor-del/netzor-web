# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Production on Render — use PostgreSQL instead, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/netzor"

JWT_SECRET="change-this-to-a-long-random-secret-min-32-characters"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Netzor Pay — use "simulated" locally, "razorpay" in production
NETZOR_PAY_PROVIDER="simulated"
NETZOR_PAY_MERCHANT_ID="NZR-DEV-MERCHANT"
NETZOR_PAY_API_KEY="dev-api-key"

# Razorpay (Test mode keys from dashboard.razorpay.com)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_test_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

NEXT_PUBLIC_WHATSAPP_URL="https://wa.me/91XXXXXXXXXX?text=Hello%20NETZOR"
